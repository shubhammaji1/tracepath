{
    "name": "@tracepath/node",
    "version": "0.1.3",
    "description": "Node.js SDK for Tracepath",
    "keywords": [
        "observability",
        "tracing",
        "node",
        "express",
        "debugging"
    ],
    "license": "MIT",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@tracepath/core": "^0.1.2",
        "ws": "^8.16.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.5",
        "@types/ws": "^8.5.10",
        "rimraf": "^5.0.5",
        "tsup": "^8.0.2",
        "typescript": "^5.3.3",
        "vitest": "^1.2.2"
    },
    "peerDependencies": {
        "express": ">=4.0.0"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
